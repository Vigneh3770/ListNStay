 <% if(success && success.length) {  %>
    <!--  success && success.length  -->
      <!-- typeof success !== 'undefined' && success && success.length -->

    <div class="alert alert-success alert-dismissible fade show col-6 offset-3" role="alert">
        <%= success %>

        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    <% } %> 

     <%  if(deletion && deletion.length) { %>

    <div class="alert alert-danger col-6 offset-3" role="alert">
        <%= deletion %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    <% } %>

    <%  if(updation && updation.length) { %>

    <div class="alert alert-dark col-6 offset-3" role="alert">
        <%= updation %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    <% } %>

    <%  if(err && err.length) { %>

    <div class="alert alert-danger col-6 offset-3" role="alert">
        <%= err %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    <% } %>