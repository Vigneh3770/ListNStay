        <button>Add new Listing</button>
      </form>
      <ul>
        </div> -->

        <style>
          #filters{
            display: flex;
            flex-wrap: wrap;
          
          }
          .filter{
            margin-right: 2rem;
            margin-top: 1rem;
            text-align: center;
            opacity: .8;
          }
          .filter:hover{
            opacity: 1;
            cursor: pointer;
          }
          .filter p{
            font-size: .9rem;
          }
        </style>
        <div id="filters">
          <div class="filter ">
            <div> <i class="fa-solid fa-fire" style="color: rgb(252, 116, 116);"></i></div>
               <p>Trending</p>
          </div>
          <div class="filter ">
            <div> <i class="fa-solid fa-bed" style="color: rgb(252, 116, 116);"></i></div>
               <p>Rooms</p>
          </div>
          <div class="filter ">
            <div> <i class="fa-solid fa-city" style="color: rgb(252, 116, 116);"></i></div>
               <p>Iconic Cities</p>
          </div>
          <div class="filter ">
            <div> <i class="fa-solid fa-mountain" style="color: rgb(252, 116, 116);"></i></div>
               <p>Mountains</p>
          </div>
          <div class="filter ">
            <div> <i class="fa-solid fa-archway" style="color: rgb(252, 116, 116);"></i></div>
               <p>Castles</p>
          </div>
          <div class="filter ">
            <div> <i class="fa-solid fa-person-swimming" style="color: rgb(252, 116, 116);"></i></div>
               <p>Amazing Pools</p>
          </div>
          <div class="filter ">
            <div> <i class="fa-solid fa-house-flag" style="color: rgb(252, 116, 116);"></i></div>
               <p>Camping</p>
          </div>
          <div class="filter ">
            <div> <i class="fa-solid fa-cow" style="color: rgb(252, 116, 116);"></i></div>
               <p>Farms</p>
          </div>
          <div class="filter ">
            <div> <i class="fa-solid fa-snowflake" style="color: rgb(252, 116, 116);"></i></div>
               <p>Arctic</p>
          </div>
         
        </div>

  <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-1"> 


  <% for(datum of data) { %>
    <div class="card col listing-card">
      <a href="/listings/<%= datum._id %>" class="listing-link">
        <div class="card">
          <img src="<%= datum.image.url %>" class="card-img-top" alt="listingimg">
           <div class="card-img-overlay"></div>
          <div class="card-body" >
            <p class="card-text"><b><%= datum.title %></b></p>
            <p class="card-text">₹<%= datum.price %></p>
            <!-- <p class="card-text">₹  datum.price.toLocaleString("en-IN") </p> -->
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>
        
